#!/usr/bin/env python3
"""Adjudication check for the Codex and DeepSeek ADR-004/005 gate reviews."""
import subprocess, sys
sys.path.insert(0, "impl")
import sigma_wave as sw

ok = True
I = sw.W(0, 65535, -32768); K = sw.W(32768, 65535, -32768)
# R1 completion for FALSE: derive, then apply the ph pin field-level
f = sw.interfere(K, I)
print("derived FALSE:", f)
ok &= f == sw.W(32768, 0, -32512)
f["ph"] = 49152
ok &= f == sw.W(49152, 0, -32512)          # DeepSeek's normative row
anc = sw.interfere(f, I)
print("FALSE-ancestor:", anc)
ok &= anc == sw.W(49152, 0, -32640)        # Codex's WV-FALSE-ANCESTOR-SILENT
# DeepSeek's six-step decay derivation
w, seq = sw.W(0, 49151, 0), [49151]
while w["am"]:
    w = sw.interfere(w, w); seq.append(w["am"])
print("decay:", seq)
ok &= seq == [49151, 36863, 20735, 6560, 657, 7, 0]
# ADR-004 interim law unchanged
import importlib
sg = importlib.import_module("sigma_glyph")
st = sg.Store()
h = st.put(sg.ser(sg.LITERAL, sg.F_ATOM, atom=sg.sha(b"dummy blob")))
res, sp = sg.eval_hash(h, 10, st)
ok &= (res[0], sp) == ("lit", 1)
print("LIT-no-blob: lit 1")
for cmd, want in ((["impl/sigma_glyph.py"], "ALL PASS"),
                  (["impl/sigma_wave.py"], "WAVE: ALL PASS"),
                  (["tests/spec_conformance/run_reference.py"], "ALL PASS (46/46)")):
    p = subprocess.run([sys.executable] + cmd, capture_output=True, text=True)
    print(p.stdout.strip().splitlines()[-1])
    ok &= p.returncode == 0 and want in p.stdout
print("adr45 gate dispositions verified" if ok else "CHECK FAILED")
sys.exit(0 if ok else 1)
