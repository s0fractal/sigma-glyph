#!/usr/bin/env python3
"""Adjudication check: ADR-001 memory bound proven on the concrete evaluator."""
import pathlib, subprocess, sys
src = pathlib.Path("proofs/EvalMachine.lean").read_text()
# the three memory-bound theorems must be present and sorry-free
ok = all(name in src for name in
         ("theorem size_step", "theorem eval_size_bound", "theorem evalHash_size_bound"))
ok &= "sorry" not in src and "admit" not in src
print("memory-bound theorems present, no sorry" if ok else "THEOREMS MISSING/SORRY")
# the eval bridge compiles EvalMachine (theorems check on compile) + differential
p = subprocess.run([sys.executable, "proofs/eval_bridge_check.py"],
                   capture_output=True, text=True)
sys.stdout.write(p.stdout)
ok &= p.returncode == 0 and "EVAL-BRIDGE: ALL AGREE (33/33)" in p.stdout
# no regression across all four Lean fronts
for mod in ("SizeBound", "WaveAlgebra", "MachineBytes", "EvalMachine"):
    q = subprocess.run(["lean", f"proofs/{mod}.lean"], capture_output=True, text=True)
    okm = q.returncode == 0
    ok &= okm
    print(f"proofs/{mod}.lean: {'checks' if okm else 'BROKE'}")
print("memory bound on the concrete evaluator verified" if ok else "CHECK FAILED")
sys.exit(0 if ok else 1)
