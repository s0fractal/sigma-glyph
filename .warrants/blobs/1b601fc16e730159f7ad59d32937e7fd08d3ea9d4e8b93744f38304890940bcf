#!/usr/bin/env python3
"""Adjudication check: Book I evaluator mechanization (repo root; needs elan/lean)."""
import subprocess, sys
p = subprocess.run([sys.executable, "proofs/eval_bridge_check.py"],
                   capture_output=True, text=True)
sys.stdout.write(p.stdout)
ok = p.returncode == 0 and "EVAL-BRIDGE: ALL AGREE (33/33)" in p.stdout
# the other three Lean fronts must still check (no regression)
for mod in ("proofs/SizeBound.lean", "proofs/WaveAlgebra.lean", "proofs/MachineBytes.lean"):
    q = subprocess.run(["lean", mod], capture_output=True, text=True)
    okm = q.returncode == 0
    ok &= okm
    print(f"{mod}: {'checks' if okm else 'BROKE'}")
print("evaluator mechanization verified" if ok else "CHECK FAILED")
sys.exit(0 if ok else 1)
