#!/usr/bin/env python3
"""v0.6.0 adoption gate: all suites, both federation impls, anchors, warrants."""
import subprocess, sys
ok = True
for cmd, want in (([sys.executable, "impl/sigma_glyph.py"], "ALL PASS"),
                  ([sys.executable, "impl/sigma_wave.py"], "WAVE: ALL PASS (30/30)"),
                  ([sys.executable, "impl/sigma_federation.py"], "FEDERATION: ALL PASS (37/37)"),
                  (["./impl-go/sigma-federation-go", "replay", "tests/spec_conformance/federation_vectors.json"], "FEDERATION-GO: ALL PASS (21/21)"),
                  ([sys.executable, "tests/federation_differential.py"], "FEDERATION-DIFFERENTIAL: ALL AGREE (40/40)"),
                  ([sys.executable, "tests/spec_conformance/run_reference.py"], "ALL PASS (49/49)"),
                  ([sys.executable, "tests/spec_conformance/test_properties.py"], "PROPERTIES: ALL PASS"),
                  ([sys.executable, "tools/verify_anchors.py"], "anchors verified"),
                  ([sys.executable, "tools/check_lazy_edges.py"], "lazy edges sealed"),
                  ([sys.executable, "tools/warrant_verify.py"], "errors 0")):
    p = subprocess.run(cmd, capture_output=True, text=True)
    last = p.stdout.strip().splitlines()[-1]
    print(last)
    ok &= p.returncode == 0 and want in last
print("v0.6.0 adoption gates green" if ok else "GATES FAILED")
sys.exit(0 if ok else 1)
