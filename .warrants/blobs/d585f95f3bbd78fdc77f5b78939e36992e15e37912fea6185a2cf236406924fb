#!/usr/bin/env python3
"""Adjudication check for Kimi's ADR-006 gate review 3 (repo root)."""
import subprocess, sys
sys.path.insert(0, "impl")
import sigma_wave as sw
ok = True
w1, w2, w3 = sw.W(0,65535,0), sw.W(16384,65535,0), sw.W(16384,65535,0)
ok &= sw.interfere(sw.interfere(w1,w2), w3) == sw.W(0,16384,0)
ok &= sw.interfere(w1, sw.interfere(w2,w3)) == sw.W(0,32768,-128)
print("kimi probe 1 exact (2x amplitude divergence by grouping)")
A, B, C = sw.W(8192,65535,0), sw.W(8192,65535,-256), sw.W(8192,65535,-256)
ok &= sw.interfere(sw.interfere(A,B), C)["en"] == -576
ok &= sw.interfere(A, sw.interfere(B,C))["en"] == -512
print("kimi probe 2 exact (same-phase entropy split)")
for cmd, want in ((["impl/sigma_wave.py"], "WAVE: ALL PASS"),
                  (["tools/warrant_verify.py"], "errors 0")):
    p = subprocess.run([sys.executable] + cmd, capture_output=True, text=True)
    last = p.stdout.strip().splitlines()[-1]; print(last)
    ok &= p.returncode == 0 and want in last
print("adr006 gate 3 dispositions verified" if ok else "CHECK FAILED")
sys.exit(0 if ok else 1)
