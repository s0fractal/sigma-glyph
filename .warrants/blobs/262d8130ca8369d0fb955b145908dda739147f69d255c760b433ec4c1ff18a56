#!/usr/bin/env python3
"""Adjudication check for the Codex pedantic audit (sigma, repo root)."""
import pathlib, subprocess, sys
ok = True
ci = pathlib.Path(".github/workflows/ci.yml").read_text()
ok &= "set -euo pipefail" in ci and "| tail -1" not in ci
print("P1: no tail-masking in CI, pipefail set")
b2 = pathlib.Path("spec/book-2-navigation.md").read_text()
ok &= "майбутній документ" not in b2 and "**Version:** 0.6.1" in b2
b3 = pathlib.Path("spec/book-3-federation.md").read_text()
ok &= "Пони" not in b3 and "suject" not in b3 and "Merkle-корінь замість" not in b3
print("anchored prose fixes present")
ok &= "Bundle convention" in pathlib.Path("spec/ANCHORS.txt").read_text()
ok &= "The Three Books" in pathlib.Path("README.md").read_text()
ok &= "format_version: 2" in pathlib.Path("tests/spec_conformance/README.md").read_text()
print("bundle convention + README + suite README fixed")
for cmd, want in ((["impl/sigma_glyph.py"], "ALL PASS"),
                  (["impl/sigma_wave.py"], "WAVE: ALL PASS (30/30)"),
                  (["impl/sigma_federation.py"], "FEDERATION: ALL PASS (37/37)"),
                  (["tests/federation_differential.py"], "ALL AGREE (40/40)"),
                  (["tests/spec_conformance/run_reference.py"], "ALL PASS (49/49)"),
                  (["tools/verify_anchors.py"], "anchors verified"),
                  (["tools/warrant_verify.py"], "errors 0")):
    p = subprocess.run([sys.executable] + cmd, capture_output=True, text=True)
    last = p.stdout.strip().splitlines()[-1]; print(last)
    ok &= p.returncode == 0 and want in last
print("pedantic sigma dispositions verified" if ok else "CHECK FAILED")
sys.exit(0 if ok else 1)
