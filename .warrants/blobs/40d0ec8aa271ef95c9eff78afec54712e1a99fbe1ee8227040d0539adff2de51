#!/usr/bin/env python3
"""Adjudication check for Codex's ADR-006 gate review (repo root)."""
import subprocess, sys
sys.path.insert(0, "impl")
import sigma_wave as sw
ok = True
a, b = sw.W(8192,30000,100), sw.W(40960,20000,-100)
ok &= sw.interfere(a,b) == sw.W(8192,0,256) and sw.interfere(b,a) == sw.W(40960,0,256)
c, d = sw.W(0,50000,0), sw.W(16384,40000,0)
ok &= sw.interfere(c,d)["ph"] == 0 and sw.interfere(d,c)["ph"] == 16384
ok &= sw.interfere(c,d)["am"] == sw.interfere(d,c)["am"] == 15259
print("order-dependence probes exact")
ok &= sw.iterate_am(sw.W(0,49151,0)) == [49151,36863,20735,6560,657,7,0]
ok &= sw.interfere(sw.W(12345,65535,-32768), sw.W(12345,65535,-32768)) == sw.W(12345,65535,-32768)
print("decay + fixed point exact")
for cmd, want in ((["impl/sigma_wave.py"], "WAVE: ALL PASS"),
                  (["tools/warrant_verify.py"], "errors 0")):
    p = subprocess.run([sys.executable] + cmd, capture_output=True, text=True)
    last = p.stdout.strip().splitlines()[-1]; print(last)
    ok &= p.returncode == 0 and want in last
print("adr006 gate 2 dispositions verified" if ok else "CHECK FAILED")
sys.exit(0 if ok else 1)
