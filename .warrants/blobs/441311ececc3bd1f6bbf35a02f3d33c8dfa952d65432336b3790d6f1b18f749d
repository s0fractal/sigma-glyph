```

I also traced constructed duplication candidates:

```bash
python3 - <<'PY'
import sys
sys.path.insert(0,'impl')
import sigma_glyph as sg
st=sg.Store(); A=lambda l,r:('app',l,r)
Ig,Kg,Sg=('lit',sg.sha(b'I')),('lit',sg.sha(b'K')),('lit',sg.sha(b'S'))
def put_tree(t):
    if t[0]=='app': put_tree(t[1]); put_tree(t[2])
    return st.put(sg.term_bytes(t))
for b in (sg.I_BYTES, sg.K_BYTES, sg.S_BYTES, sg.FALSE_BYTES): st.put(b)
def trace(h, budget=10000):
    t=('thunk',h); spent=0; smax=sg.size(t); steps=0; stats={'fetches':0}
    try:
        while True:
            rr=sg.step5(t,budget-spent,st,stats,sg.DEFAULT_LIMITS)
            if rr is None: return 'nf', sg.term_hash(t).hex(), spent, smax, steps, smax-1<=spent
            t=rr[0]; spent+=rr[1]; steps+=1; smax=max(smax,sg.size(t))
    except sg.BudgetExhausted:
        return 'atp', sg.node_hash(sg.ser(sg.DISSONANCE, sg.F_ATOM, atom=sg.R_ATP)).hex(), spent, smax, steps, smax-1<=spent
    except sg.Unresolved:
        return 'unres', sg.node_hash(sg.ser(sg.DISSONANCE, sg.F_ATOM, atom=sg.R_UNRES)).hex(), spent, smax, steps, smax-1<=spent
candidates=[]
T=A(A(A(Sg,Ig),Ig),A(Ig,Kg)); candidates.append(('TV6 S I I (I K)', T))
W=A(A(Sg,Ig),Ig); candidates.append(('Omega prefix budget 500', A(W,W)))
payload=A(Ig,Kg)
for n in range(1,5):
    term=A(A(A(Sg,Ig),Ig),payload)
    candidates.append((f'dup-chain-{n}', term))
    payload=term
for name,t in candidates:
    h=put_tree(t)
    budget=500 if 'Omega' in name else 10000
    print(name, trace(h,budget))
