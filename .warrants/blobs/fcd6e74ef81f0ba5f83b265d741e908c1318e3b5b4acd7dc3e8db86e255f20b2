#!/usr/bin/env python3
"""Adjudication check for the Codex Book III implementation-gate review (repo root)."""
import subprocess, sys
sys.path.insert(0, "impl")
from sigma_federation import (select, validate_policy, ASSERTION_TAG, W,
                              assertion_set_root)
J = "aa" * 32; NODE = "cc" * 32
ok = True
def cand(wid, actor, ts=1, epoch=1, node=NODE, jur=J):
    return {"warrant_id": wid * 64, "actor": actor, "ts": ts,
            "assertion": {"annotation": ASSERTION_TAG, "jurisdiction": jur,
                          "node": node, "epoch": epoch, "wave": W(0, 1, 0)}}
pol = {"federation_policy": "sigma-glyph.selection@v1",
       "order": [{"field": "actor", "dir": "desc"}]}
# P1-1: prefix pair + non-ASCII totality (the review's exact probes)
r = select([cand("1", "a"), cand("2", "aa")], pol, J, NODE, 1)
ok &= r["selected"]["actor"] == "aa"
r = select([cand("1", "Ā"), cand("2", "a")], pol, J, NODE, 1)
ok &= r["selected"]["actor"] == "Ā"
print("P1-1 actor desc fixed (prefix + non-ASCII)")
# P1-2: node binding
pol_e = {"federation_policy": "sigma-glyph.selection@v1",
         "order": [{"field": "epoch", "dir": "desc"}]}
r = select([cand("1", "x", epoch=1), cand("2", "y", epoch=2, node="dd"*32)], pol_e, J, NODE, 2)
ok &= r["selected"]["warrant_id"] == "1" * 64
print("P1-2 node-bound selection")
# P1-3: future excluded
r = select([cand("1", "x", epoch=8), cand("2", "y", epoch=9)], pol_e, J, NODE, 8)
ok &= r["selected"]["warrant_id"] == "1" * 64
print("P1-3 future-epoch excluded")
# P1-4: quota follows policy order
pol_q = {"federation_policy": "sigma-glyph.selection@v1",
         "order": [{"field": "ts", "dir": "desc"}], "quota_per_actor_epoch": 1}
r = select([cand("1", "s", ts=100, epoch=5), cand("2", "s", ts=200, epoch=5)], pol_q, J, NODE, 5)
ok &= r["selected"]["warrant_id"] == "2" * 64
print("P1-4 quota survivors follow policy order (ts=200 kept)")
# P1-5: peer-root fields stay invalid
ok &= validate_policy({"federation_policy": "sigma-glyph.selection@v1",
                       "order": [{"field": "epoch", "dir": "desc"}],
                       "federated_peer_roots": ["bb"*32]}) is not None
print("P1-5 no peer roots in v0.6 policy schema")
for cmd, want in ((["impl/sigma_federation.py"], "FEDERATION: ALL PASS (37/37)"),
                  (["impl/sigma_glyph.py"], "ALL PASS"),
                  (["impl/sigma_wave.py"], "WAVE: ALL PASS"),
                  (["tests/spec_conformance/run_reference.py"], "ALL PASS (49/49)"),
                  (["tools/verify_anchors.py"], "anchors verified"),
                  (["tools/warrant_verify.py"], "errors 0")):
    p = subprocess.run([sys.executable] + cmd, capture_output=True, text=True)
    last = p.stdout.strip().splitlines()[-1]; print(last)
    ok &= p.returncode == 0 and want in last
print("book3 gate dispositions verified" if ok else "CHECK FAILED")
sys.exit(0 if ok else 1)
