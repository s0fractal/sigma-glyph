#!/usr/bin/env python3
"""Adjudication check: Gemini 3.1 Pro external-audit fixes (sigma-glyph root)."""
import os, subprocess, sys
root=os.getcwd(); ok=True
def gate(cmd,want):
    global ok
    p=subprocess.run(cmd,capture_output=True,text=True,cwd=root)
    last=p.stdout.strip().splitlines()[-1] if p.stdout.strip() else "(no output)"
    good=p.returncode==0 and want in p.stdout
    print(f"{'ok ' if good else 'FAIL'} {' '.join(cmd[:3])} -> {last}"); ok&=good
gate(["python3","impl/sigma_glyph.py"],"ALL PASS")
gate(["python3","impl/sigma_wave.py"],"WAVE: ALL PASS")
gate(["python3","impl/sigma_federation.py"],"FEDERATION: ALL PASS")
gate(["python3","tests/federation_differential.py"],"FEDERATION-DIFFERENTIAL: ALL AGREE")
gate(["python3","tests/governance_differential.py"],"GOVERNANCE-DIFFERENTIAL: ALL AGREE")
gate(["python3","tools/anchor_governance.py","selftest"],"ANCHOR-GOVERNANCE: ALL PASS")
gate(["python3","tools/warrant_verify.py"],"errors 0")
gate(["python3","tools/verify_anchors.py"],"anchors verified")
rust=os.path.join(root,"impl-rs/target/release/book1")
if os.path.exists(rust): gate([rust,"conformance","tests/spec_conformance/vectors.json"],"RUST-CONFORMANCE: ALL PASS")
wgo=os.path.expanduser("~/Projects/warrant/impl-go/warrant-go")
if os.path.exists(wgo):
    gate([wgo,"sigma-conformance","tests/spec_conformance/vectors.json"],"SIGMA CONFORMANCE: ALL PASS")
    env=dict(os.environ, RUST_BOOK1=rust, WARRANT_GO=wgo)
    for s in ("1337","4242"):
        p=subprocess.run(["python3","tests/book1_fuzz.py","--terms","150","--seed",s],capture_output=True,text=True,cwd=root,env=env)
        last=p.stdout.strip().splitlines()[-1] if p.stdout.strip() else "(no output)"
        good=p.returncode==0 and "BOOK1-FUZZ: ALL AGREE" in p.stdout
        print(f"{'ok ' if good else 'FAIL'} book1_fuzz seed={s} -> {last}"); ok&=good
print("gemini audit sigma-side verified" if ok else "CHECK FAILED"); sys.exit(0 if ok else 1)
