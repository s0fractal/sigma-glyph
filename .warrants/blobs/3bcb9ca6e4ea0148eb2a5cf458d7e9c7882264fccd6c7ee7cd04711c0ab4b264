#!/usr/bin/env python3
"""Adjudication check for the ADR-007 gate round 1 (sigma-glyph repo root).

Verifies every load-bearing rev 2 disposition is real, then runs the
governance selftest and the affected gates."""
import pathlib, subprocess, sys
ok = True
tool = pathlib.Path("tools/anchor_governance.py").read_text()
ok &= "refusing to authorize" in tool                # Gemini A: fail-closed crypto
ok &= "def settlement_closure" in tool               # GPT-5 P1-A: Warrant s9 scoping
ok &= '"jurisdiction"' in tool                       # DeepSeek/GPT-5 2:1: embedded root
ok &= "chain frozen" in tool                         # DeepSeek 6.1: conflict freeze, no tie-break
ok &= '"threshold": str' not in tool and 'doc["threshold"]' in tool  # profile pins threshold
ok &= "out-of-band" in tool                          # Gemini ask-1: no in-tree trust anchor
print("tool dispositions present (fail-closed, closure, jurisdiction, freeze, pin, out-of-band)")
adr = pathlib.Path("proposals/ADR-007-governed-anchors.md").read_text()
ok &= "PROPOSED, rev 2" in adr and "policy-lineage rule" in adr
ok &= "grindable" in adr and "N − M" in adr
print("ADR rev 2 markers present (lineage, grindable tie-break rejection, N-M liveness)")
p = subprocess.run([sys.executable, "tools/anchor_governance.py", "selftest"],
                   capture_output=True, text=True)
last = p.stdout.strip().splitlines()[-1]; print(last)
ok &= p.returncode == 0 and "ALL PASS" in last
p = subprocess.run([sys.executable, "tools/anchor_governance.py", "status", "--enforce"],
                   capture_output=True, text=True)
ok &= p.returncode == 1                              # Gemini B: UNGOVERNED cannot green enforced CI
print("status --enforce exits 1 while ungoverned")
p = subprocess.run([sys.executable, "tools/anchor_governance.py", "status",
                    "--trust-config", "trust-config.json"], capture_output=True, text=True)
ok &= p.returncode == 1 and "out-of-band" in p.stdout   # in-tree trust path refused
print("in-tree trust config path refused")
for cmd, want in ((["examples/two-jurisdictions/demo.py"], "DEMO: ALL ASSERTIONS HELD"),
                  (["tools/verify_anchors.py"], "anchors verified"),
                  (["tools/warrant_verify.py"], "errors 0")):
    p = subprocess.run([sys.executable] + cmd, capture_output=True, text=True)
    last = p.stdout.strip().splitlines()[-1]; print(last)
    ok &= p.returncode == 0 and want in last
print("ADR-007 gate round 1 dispositions verified" if ok else "CHECK FAILED")
sys.exit(0 if ok else 1)
