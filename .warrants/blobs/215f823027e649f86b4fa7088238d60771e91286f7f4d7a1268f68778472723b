#!/usr/bin/env python3
"""Adjudication check for Gemini's ADR-006 gate review (repo root)."""
import subprocess, sys
sys.path.insert(0, "impl")
import sigma_wave as sw
ok = True
w1, w2, w3 = sw.W(8192,40000,-100), sw.W(16384,30000,50), sw.W(49152,60000,-2000)
l = sw.interfere(sw.interfere(w1,w2), w3); r = sw.interfere(w1, sw.interfere(w2,w3))
print("assoc probe:", l, "vs", r)
ok &= l != r and l == sw.W(8192,2096,-922) and r == sw.W(8192,0,-591)
ok &= sw.interfere(w1,w2) != sw.interfere(w2,w1)
for cmd, want in ((["impl/sigma_wave.py"], "WAVE: ALL PASS"),
                  (["impl/sigma_glyph.py"], "ALL PASS"),
                  (["tools/warrant_verify.py"], "errors 0")):
    p = subprocess.run([sys.executable] + cmd, capture_output=True, text=True)
    last = p.stdout.strip().splitlines()[-1]; print(last)
    ok &= p.returncode == 0 and want in last
print("adr006 gate 1 dispositions verified" if ok else "CHECK FAILED")
sys.exit(0 if ok else 1)
